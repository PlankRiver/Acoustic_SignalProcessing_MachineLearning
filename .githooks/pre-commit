#!/usr/bin/env bash
set -euo pipefail

# Dataset commit guard.
# Override in rare cases: BYPASS_DATASET_GUARD=1 git commit ...
if [[ "${BYPASS_DATASET_GUARD:-0}" == "1" ]]; then
  exit 0
fi

# Limits only for lightweight reference dataset files:
# .jpg/.jpeg/.png/.wav/.mat/.csv
MAX_REFERENCE_FILES="${DATASET_REFERENCE_MAX_FILES:-40}"
MAX_REFERENCE_BYTES="${DATASET_REFERENCE_MAX_BYTES:-12582912}" # 12 MB
MAX_REFERENCE_SINGLE_FILE_BYTES="${DATASET_REFERENCE_MAX_SINGLE_FILE_BYTES:-2097152}" # 2 MB

sample_allowed_regex='(^|/)(data|dataset|datasets)/samples(/|$)|(^|/)sample_data(/|$)'
reference_ext_regex='\.(jpg|jpeg|png|wav|mat|csv)$'

reference_file_count=0
reference_total_bytes=0
blocked_paths=()
reference_oversized_files=()
blocked_text_json_paths=()

while IFS= read -r -d '' file; do
  [[ -f "$file" ]] || continue

  lower_file="${file,,}"
  if [[ "$lower_file" =~ \.(txt|json)$ ]]; then
    blocked_text_json_paths+=("$file")
    continue
  fi

  if [[ ! "$lower_file" =~ $reference_ext_regex ]]; then
    continue
  fi

  size_bytes=$(wc -c < "$file" | tr -d ' ')
  reference_file_count=$((reference_file_count + 1))
  reference_total_bytes=$((reference_total_bytes + size_bytes))

  if [[ ! "$lower_file" =~ $sample_allowed_regex ]]; then
    blocked_paths+=("$file")
  fi

  if (( size_bytes > MAX_REFERENCE_SINGLE_FILE_BYTES )); then
    reference_oversized_files+=("$file ($size_bytes bytes)")
  fi
done < <(git diff --cached --name-only --diff-filter=ACM -z)

if (( ${#blocked_text_json_paths[@]} > 0 )); then
  echo "[dataset-guard] Commit blocked: .txt and .json files are not allowed in this repository."
  echo "Unstage or rename these files:"
  printf '  - %s\n' "${blocked_text_json_paths[@]}"
  exit 1
fi

if (( ${#blocked_paths[@]} > 0 )); then
  echo "[dataset-guard] Commit blocked: detected restricted reference files outside samples directories."
  echo "Allowed samples directories: data/samples/, datasets/samples/, sample_data/"
  echo "Move these files into sample dirs or unstage them:"
  printf '  - %s\n' "${blocked_paths[@]}"
  exit 1
fi

if (( ${#reference_oversized_files[@]} > 0 )); then
  echo "[dataset-guard] Commit blocked: single reference file exceeds stricter limit ${MAX_REFERENCE_SINGLE_FILE_BYTES} bytes."
  printf '  - %s\n' "${reference_oversized_files[@]}"
  exit 1
fi

if (( reference_file_count > MAX_REFERENCE_FILES )); then
  echo "[dataset-guard] Commit blocked: reference-file count ${reference_file_count} > ${MAX_REFERENCE_FILES} for .jpg/.png/.wav/.mat/.csv."
  exit 1
fi

if (( reference_total_bytes > MAX_REFERENCE_BYTES )); then
  echo "[dataset-guard] Commit blocked: total reference-file size ${reference_total_bytes} bytes > ${MAX_REFERENCE_BYTES} bytes for .jpg/.png/.wav/.mat/.csv."
  exit 1
fi

exit 0
